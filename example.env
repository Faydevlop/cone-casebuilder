# The URL of your published Google Web App script
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/.../exec

# Comma-separated list of creator emails allowed to publish scenarios
VITE_ALLOWED_EMAILS=user1@gmail.com,user2@gmail.com

# Password required to log in as a scenario creator
VITE_EMAIL_PASSWORD=creatorPassword123

# Email required to log in as a scenario checker
VITE_CHECKER_EMAIL=checker@gmail.com

# Password required to log in as a scenario checker
VITE_CHECKER_PASSWORD=checkerPassword123
